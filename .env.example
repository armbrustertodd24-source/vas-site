# ─────────────────────────────────────────────────────────────────────────
# Copy to .env.local (dev) or set these in your host's secret store (prod).
# NEVER commit a real .env file. All values below are placeholders.
# ─────────────────────────────────────────────────────────────────────────

# ── Database (Railway Postgres) ──
# Use the Railway-provided connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname"
# TLS mode for the DB connection:
#   require   (default) – TLS required; use for Railway's PUBLIC proxy
#   no-verify – TLS required, certificate not verified
#   disable   – no TLS; ONLY if app + DB share Railway's PRIVATE network
DATABASE_SSL="require"
# Optional: max connections in the pool (default 10)
# DATABASE_POOL_MAX="10"

# ── Auth.js (NextAuth) — OAuth only, no passwords stored ──
# Generate with:  npx auth secret
AUTH_SECRET="replace-with-a-long-random-secret"
# Google OAuth credentials (console.cloud.google.com → Credentials)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
# Public URL of the app in production (e.g. https://yourdomain.com)
AUTH_URL="http://localhost:3000"

# ── Stripe (card data never touches this server) ──
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs created in the Stripe dashboard (Products → Prices)
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
STRIPE_PRICE_FOUNDING="price_..."

# ── App ──
# Used for Checkout success/cancel redirects (must be the public URL in prod)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
